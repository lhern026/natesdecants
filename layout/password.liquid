<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <title>{{ shop.name }}</title>
    {{ content_for_header }}
    <link rel="stylesheet" href="{{ 'theme.css' | asset_url }}">
    <style>
      body { margin: 0; background: #0a0a0a; color: #fdfbf7; display: flex; align-items: center; justify-content: center; min-height: 100vh; font-family: 'Inter', sans-serif; }
      .password-page { text-align: center; padding: 2rem; max-width: 480px; }
      .password-page h1 { font-size: 2rem; margin-bottom: 1rem; }
      .password-page p { opacity: 0.6; margin-bottom: 2rem; }
      .password-page input { width: 100%; padding: 0.875rem 1rem; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); color: #fdfbf7; border-radius: 8px; margin-bottom: 1rem; font-size: 1rem; }
      .password-page button { width: 100%; padding: 0.875rem; background: #b68c5d; color: #0a0a0a; border: none; border-radius: 8px; font-size: 0.875rem; letter-spacing: 0.05em; text-transform: uppercase; cursor: pointer; }
    </style>
  </head>
  <body>
    {{ content_for_layout }}
  </body>
</html>
