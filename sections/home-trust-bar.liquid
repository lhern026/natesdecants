<div class="trust-bar reveal">
  <div class="container">
    <div class="trust-bar-grid">
      {%- for block in section.blocks -%}
        <div class="trust-item" {{ block.shopify_attributes }}>
          {%- if block.settings.icon != blank -%}
            <img src="{{ block.settings.icon | image_url: width: 56 }}" alt="" width="28" height="28" loading="lazy">
          {%- else -%}
            {%- case block.settings.icon_preset -%}
              {%- when 'shield' -%}
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              {%- when 'truck' -%}
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3"><rect x="1" y="3" width="15" height="13" rx="1"/><path d="M16 8h4l3 3v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
              {%- when 'check' -%}
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3"><path d="M3 12a9 9 0 1 0 18 0 9 9 0 0 0-18 0"/><path d="m9 12 2 2 4-4"/></svg>
              {%- when 'heart' -%}
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78L12 21.23l8.84-8.84a5.5 5.5 0 0 0 0-7.78z"/></svg>
              {%- else -%}
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            {%- endcase -%}
          {%- endif -%}
          <span class="trust-item-title">{{ block.settings.title }}</span>
          <p class="trust-item-desc">{{ block.settings.description }}</p>
        </div>
      {%- else -%}
        <div class="trust-item">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          <span class="trust-item-title">100% Authentic</span>
          <p class="trust-item-desc">Sourced exclusively from authorized retailers</p>
        </div>
        <div class="trust-item">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3"><rect x="1" y="3" width="15" height="13" rx="1"/><path d="M16 8h4l3 3v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
          <span class="trust-item-title">Ships in 1–3 Days</span>
          <p class="trust-item-desc">Insured delivery in protective packaging</p>
        </div>
        <div class="trust-item">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3"><path d="M3 12a9 9 0 1 0 18 0 9 9 0 0 0-18 0"/><path d="m9 12 2 2 4-4"/></svg>
          <span class="trust-item-title">14-Day Returns</span>
          <p class="trust-item-desc">Not satisfied? Full refund, no questions</p>
        </div>
        <div class="trust-item">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78L12 21.23l8.84-8.84a5.5 5.5 0 0 0 0-7.78z"/></svg>
          <span class="trust-item-title">Free Over $50</span>
          <p class="trust-item-desc">Free shipping on all orders above $50</p>
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Trust Bar",
  "blocks": [
    {
      "type": "item",
      "name": "Trust Item",
      "settings": [
        {
          "type": "select",
          "id": "icon_preset",
          "label": "Icon",
          "options": [
            { "value": "shield",  "label": "Shield" },
            { "value": "truck",   "label": "Truck" },
            { "value": "check",   "label": "Check circle" },
            { "value": "heart",   "label": "Heart" }
          ],
          "default": "shield"
        },
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Custom icon (overrides preset above)"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Trust signal"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description",
          "default": "Short supporting text."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trust Bar",
      "blocks": [
        { "type": "item", "settings": { "icon_preset": "shield", "title": "100% Authentic", "description": "Sourced exclusively from authorized retailers" } },
        { "type": "item", "settings": { "icon_preset": "truck",  "title": "Ships in 1–3 Days", "description": "Insured delivery in protective packaging" } },
        { "type": "item", "settings": { "icon_preset": "check",  "title": "14-Day Returns", "description": "Not satisfied? Full refund, no questions" } },
        { "type": "item", "settings": { "icon_preset": "heart",  "title": "Free Over $50", "description": "Free shipping on all orders above $50" } }
      ]
    }
  ]
}
{% endschema %}
