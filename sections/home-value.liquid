<section class="value-section reveal">
  <div class="container">
    <div class="value-section-inner">
      <div class="value-section-text">
        <span class="eyebrow">{{ section.settings.eyebrow | default: 'The Math Is Simple' }}</span>
        <h2>{{ section.settings.heading | default: 'Spend smarter.' | newline_to_br }}<br><em>{{ section.settings.heading_italic | default: 'Smell better.' }}</em></h2>
        <p>{{ section.settings.body | default: 'Most people wear the same 2 scents their whole life — not because they love them, but because committing to a $400 bottle feels like a gamble. We fixed that.' }}</p>
        <a href="{{ section.settings.button_link | default: routes.collections_url }}" class="btn btn--primary" style="margin-top: var(--space-lg);">
          {{ section.settings.button_label | default: 'Start Exploring' }}
          <span class="btn-arrow">→</span>
        </a>
      </div>
      <div class="price-comparison">
        <div class="price-card price-card--retail">
          <span class="price-card-label">{{ section.settings.retail_label | default: 'Full Bottle' }}</span>
          <span class="price-card-name">{{ section.settings.retail_name | default: 'Creed Aventus 100ml EDP' }}</span>
          <span class="price-card-price">{{ section.settings.retail_price | default: '$435' }}</span>
          <span class="price-card-note">{{ section.settings.retail_note | default: "What if you don't love it?" }}</span>
        </div>
        <div class="price-vs">vs</div>
        <div class="price-card price-card--decant">
          <span class="price-card-label">{{ section.settings.decant_label | default: 'Our Decant' }}</span>
          <span class="price-card-name">{{ section.settings.decant_name | default: 'Creed Aventus 10ml Discovery' }}</span>
          <span class="price-card-price">{{ section.settings.decant_price | default: '$55' }}</span>
          <span class="price-card-note">{{ section.settings.decant_note | default: 'Save $380 — love it first.' }}</span>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Value Proposition",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "The Math Is Simple"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Spend smarter."
    },
    {
      "type": "text",
      "id": "heading_italic",
      "label": "Heading (italic line)",
      "default": "Smell better."
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body text",
      "default": "Most people wear the same 2 scents their whole life — not because they love them, but because committing to a $400 bottle feels like a gamble. We fixed that."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Start Exploring"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Retail card"
    },
    {
      "type": "text",
      "id": "retail_label",
      "label": "Card label",
      "default": "Full Bottle"
    },
    {
      "type": "text",
      "id": "retail_name",
      "label": "Product name",
      "default": "Creed Aventus 100ml EDP"
    },
    {
      "type": "text",
      "id": "retail_price",
      "label": "Price (display text)",
      "default": "$435"
    },
    {
      "type": "text",
      "id": "retail_note",
      "label": "Note",
      "default": "What if you don't love it?"
    },
    {
      "type": "header",
      "content": "Decant card"
    },
    {
      "type": "text",
      "id": "decant_label",
      "label": "Card label",
      "default": "Our Decant"
    },
    {
      "type": "text",
      "id": "decant_name",
      "label": "Product name",
      "default": "Creed Aventus 10ml Discovery"
    },
    {
      "type": "text",
      "id": "decant_price",
      "label": "Price (display text)",
      "default": "$55"
    },
    {
      "type": "text",
      "id": "decant_note",
      "label": "Note",
      "default": "Save $380 — love it first."
    }
  ],
  "presets": [
    {
      "name": "Value Proposition"
    }
  ]
}
{% endschema %}
