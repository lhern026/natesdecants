<section class="video-section section-gap reveal">
  <div class="container">

    {%- if section.settings.eyebrow != blank or section.settings.heading != blank -%}
      <div class="video-header" style="text-align: center; margin-bottom: var(--space-lg);">
        {%- if section.settings.eyebrow != blank -%}
          <span class="eyebrow">{{ section.settings.eyebrow }}</span>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="display-lg" style="margin-top: var(--space-sm);">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.subheading != blank -%}
          <p class="body-text" style="margin: var(--space-md) auto 0; text-align: center;">{{ section.settings.subheading }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="video-wrapper">
      {%- if section.settings.video_url != blank -%}
        {%- if section.settings.video_url.type == 'youtube' -%}
          <iframe
            src="https://www.youtube.com/embed/{{ section.settings.video_url.id }}?autoplay={{ section.settings.autoplay }}&mute={{ section.settings.autoplay }}&loop={{ section.settings.loop }}&controls={{ section.settings.show_controls }}&playlist={{ section.settings.video_url.id }}&rel=0&modestbranding=1"
            frameborder="0"
            allow="autoplay; encrypted-media"
            allowfullscreen
            loading="lazy"
            title="{{ section.settings.heading | default: 'Brand Video' }}"
          ></iframe>
        {%- elsif section.settings.video_url.type == 'vimeo' -%}
          <iframe
            src="https://player.vimeo.com/video/{{ section.settings.video_url.id }}?autoplay={{ section.settings.autoplay }}&muted={{ section.settings.autoplay }}&loop={{ section.settings.loop }}&title=0&byline=0&portrait=0"
            frameborder="0"
            allow="autoplay; encrypted-media"
            allowfullscreen
            loading="lazy"
            title="{{ section.settings.heading | default: 'Brand Video' }}"
          ></iframe>
        {%- endif -%}

      {%- elsif section.settings.shopify_video != blank -%}
        {{
          section.settings.shopify_video
          | video_tag:
            autoplay: section.settings.autoplay,
            loop: section.settings.loop,
            muted: true,
            controls: section.settings.show_controls,
            image_size: '1920x'
        }}

      {%- else -%}
        <div class="video-placeholder">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
            <polygon points="5 3 19 12 5 21 5 3"/>
          </svg>
          <p class="eyebrow" style="margin-top: var(--space-sm);">Add a YouTube, Vimeo, or Shopify video in the section settings</p>
        </div>
      {%- endif -%}
    </div>

  </div>
</section>

{% style %}
  .video-wrapper {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: var(--radius-sm);
    overflow: hidden;
    background: #0a0a0a;
  }

  .video-wrapper iframe,
  .video-wrapper video {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .video-placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    color: var(--ink-tertiary);
    background: var(--accent-soft);
  }

  /* Cinematic letterbox effect */
  .video-wrapper::before,
  .video-wrapper::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    height: 8%;
    z-index: 2;
    pointer-events: none;
  }
  .video-wrapper::before {
    top: 0;
    background: linear-gradient(to bottom, rgba(253, 251, 247, 0.3), transparent);
  }
  .video-wrapper::after {
    bottom: 0;
    background: linear-gradient(to top, rgba(253, 251, 247, 0.3), transparent);
  }
{% endstyle %}

{% schema %}
{
  "name": "Video — Cinematic",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "The Experience"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Luxury, distilled."
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "header",
      "content": "Video Source"
    },
    {
      "type": "video_url",
      "id": "video_url",
      "label": "YouTube or Vimeo URL",
      "accept": ["youtube", "vimeo"],
      "info": "Paste a YouTube or Vimeo link here."
    },
    {
      "type": "video",
      "id": "shopify_video",
      "label": "Shopify-hosted video",
      "info": "Upload a video in Settings > Files, then select it here. Used only if no URL is provided above."
    },
    {
      "type": "header",
      "content": "Playback"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Autoplay (muted)",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "loop",
      "label": "Loop video",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_controls",
      "label": "Show playback controls",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Video — Cinematic"
    }
  ]
}
{% endschema %}
